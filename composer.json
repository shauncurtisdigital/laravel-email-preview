{
    "name": "shauncurtis/laravel-email-preview",
    "description": "A Laravel package to preview and send emails in non-production environments.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shaun Curtis"
        }
    ],
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/config": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "ShaunCurtis\\EmailPreview\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShaunCurtis\\EmailPreview\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShaunCurtis\\EmailPreview\\EmailPreviewServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "nunomaduro/larastan": "^3.9",
        "phpunit/phpunit": "^13.0",
        "laravel/framework": "^13.0",
        "orchestra/testbench": "^11.0"
    }
}
